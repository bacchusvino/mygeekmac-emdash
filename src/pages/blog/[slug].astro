---
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";

const { slug } = Astro.params;
const { entry: post, cacheHint } = await getEmDashEntry("posts", slug!);

try { Astro.cache.set(cacheHint); } catch {}

if (!post) return Astro.redirect("/blog/");

const pubDate = post.data.published_date
	? new Date(post.data.published_date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })
	: null;
---

<Base title={post.data.title} description={post.data.excerpt}>
	<article style="max-width:700px;margin:0 auto;padding:var(--space-xl) var(--space-md);">
		<header style="margin-bottom:var(--space-lg);">
			{pubDate && <p style="color:var(--warm-gray);font-size:var(--text-sm);margin-bottom:var(--space-xs);">{pubDate}</p>}
			<h1 style="font-family:var(--font-display);font-size:var(--text-2xl);line-height:1.2;">{post.data.title}</h1>
			{post.data.excerpt && <p style="color:var(--warm-gray);font-size:var(--text-lg);margin-top:var(--space-sm);">{post.data.excerpt}</p>}
		</header>

		<div class="prose">
			{post.data.content && <PortableText value={post.data.content} />}
		</div>

		<footer style="margin-top:var(--space-xl);padding-top:var(--space-lg);border-top:1px solid var(--rule);">
			<p style="color:var(--warm-gray);margin-bottom:var(--space-sm);">Need help with something mentioned in this article?</p>
			<div style="display:flex;gap:var(--space-sm);flex-wrap:wrap;">
				<a href="tel:+19514685674" class="btn btn--primary">(951) 468-5674</a>
				<a href="/contact" class="btn btn--secondary">Send a Message</a>
			</div>
		</footer>
	</article>
</Base>

<style is:global>
	.prose h2 { font-family: var(--font-display); font-size: var(--text-xl); margin: var(--space-lg) 0 var(--space-sm); }
	.prose h3 { font-family: var(--font-display); font-size: var(--text-lg); margin: var(--space-md) 0 var(--space-xs); }
	.prose p { color: var(--warm-gray); margin-bottom: var(--space-md); line-height: 1.7; }
	.prose ul, .prose ol { color: var(--warm-gray); margin: 0 0 var(--space-md) 1.5rem; }
	.prose li { margin-bottom: 0.5rem; }
	.prose a { color: var(--navy); text-decoration: underline; }
	.prose strong { color: var(--ink); }
</style>

---
import Base from "../layouts/Base.astro";
const site = Astro.locals.site as "geekmac" | "geekpc";

const serviceOptions = site === "geekpc"
	? [
		{ value: "", label: "What do you need help with?" },
		{ value: "help-now", label: "I need help right now" },
		{ value: "geek-access", label: "Geek Access ($25/mo)" },
		{ value: "personal-geek", label: "My Personal Geek ($50/mo)" },
		{ value: "geek-pro", label: "Geek Pro ($99/mo)" },
		{ value: "question", label: "I have a question" },
	]
	: [
		{ value: "", label: "What brings you here?" },
		{ value: "computer-help", label: "Computer Help (Mac or PC)" },
		{ value: "ai-help", label: "AI Consulting / Automation" },
		{ value: "coaching", label: "Coaching & Classes" },
		{ value: "remote", label: "Remote Support" },
		{ value: "other", label: "Something Else" },
	];

const locationOptions = site === "geekpc"
	? ["Idyllwild", "Pine Cove", "San Diego", "Other SoCal", "Remote"]
	: ["Idyllwild / Pine Cove", "Mountain Center / Anza", "Hemet / San Jacinto", "San Diego", "Remote (Nationwide)"];
---

<Base title={`Contact | ${site === "geekpc" ? "Senior Tech Support" : "Tech Help"} in Idyllwild, CA`} description="Call (951) 468-5674 or send a message. Reply within 2 hours. Free 15-minute discovery call.">
	<section class="page-header">
		<div class="container">
			<p class="section__eyebrow">Get In Touch</p>
			<h1 class="page-header__title">Let's Talk About Your Tech Needs</h1>
			<p class="page-header__desc">Free 15-minute discovery call. No sales pressure. No jargon.</p>
		</div>
	</section>

	<section>
		<div class="container">
			<div class="contact-section">
				<div class="contact-info">
					<div class="contact-method">
						<p class="contact-method__label">Call or Text</p>
						<p class="contact-method__value"><a href="tel:+19514685674">(951) 468-5674</a></p>
					</div>
					<div class="contact-method">
						<p class="contact-method__label">Email</p>
						<p class="contact-method__value"><a href="mailto:josh@mygeekmac.com">josh@mygeekmac.com</a></p>
					</div>
					<div class="contact-method">
						<p class="contact-method__label">Response Time</p>
						<p class="contact-method__value">Within 2 hours</p>
						<p style="color:var(--warm-gray);margin-top:0.5rem;font-size:var(--text-sm);">I respond personally — no chatbots, no ticket systems.</p>
					</div>
					<div class="contact-method">
						<p class="contact-method__label">Location</p>
						<p class="contact-method__value">Idyllwild, California</p>
					</div>
					<div style="margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid var(--rule);">
						<p style="font-weight:600;margin-bottom:0.5rem;">Service Area</p>
						<p style="color:var(--warm-gray);font-size:var(--text-sm);"><strong>On-site:</strong> Idyllwild, Pine Cove, Mountain Center, Anza, Hemet, San Jacinto, San Diego</p>
						<p style="color:var(--warm-gray);font-size:var(--text-sm);margin-top:0.5rem;"><strong>Remote:</strong> Available nationwide</p>
					</div>
					{site === "geekpc" && (
						<div style="margin-top:1.5rem;">
							<p style="color:var(--warm-gray);font-size:var(--text-sm);">PO Box 11, Idyllwild CA 92549</p>
						</div>
					)}
				</div>

				<div class="contact-form">
					<h2 style="font-family:var(--font-display);font-size:1.375rem;margin-bottom:1.5rem;">Send a Message</h2>
					<form method="POST" action="/api/contact">
						<p style="display:none;"><label>Don't fill this out: <input name="bot-field" /></label></p>
						<input type="hidden" name="site" value={site} />

						<div class="form-group">
							<label for="name" class="form-label">Your Name *</label>
							<input type="text" id="name" name="name" class="form-input" required autocomplete="name" />
						</div>

						<div class="form-group">
							<label for="phone" class="form-label">Phone Number *</label>
							<input type="tel" id="phone" name="phone" class="form-input" required autocomplete="tel" />
						</div>

						<div class="form-group">
							<label for="email" class="form-label">Email Address</label>
							<input type="email" id="email" name="email" class="form-input" autocomplete="email" />
						</div>

						<div class="form-group">
							<label for="interest" class="form-label">{site === "geekpc" ? "What do you need?" : "What brings you here?"}</label>
							<select id="interest" name="interest" class="form-select">
								{serviceOptions.map((opt) => <option value={opt.value}>{opt.label}</option>)}
							</select>
						</div>

						<div class="form-group">
							<label for="message" class="form-label">Tell me about your situation</label>
							<textarea id="message" name="message" class="form-textarea" placeholder="What's going on with your technology?"></textarea>
						</div>

						<button type="submit" class="btn btn--primary" style="width:100%;">Send Message</button>
						<p style="text-align:center;margin-top:1rem;color:var(--warm-gray);font-size:var(--text-xs);">I'll respond within 2 hours during business hours.</p>
					</form>
				</div>
			</div>
		</div>
	</section>
</Base>

---
import Base from "../layouts/Base.astro";
---

<Base title="Thank You" description="Your message has been sent.">
	<section class="thank-you">
		<div class="container" style="max-width:500px;">
			<div class="thank-you__icon">✓</div>
			<h1 class="section__title">Message Sent!</h1>
			<p style="color:var(--warm-gray);margin-bottom:var(--space-md);">Thanks for reaching out. Josh will respond within 2 hours during business hours.</p>
			<p style="color:var(--warm-gray);margin-bottom:var(--space-lg);">Need immediate help? Call <a href="tel:+19514685674" style="font-weight:600;">(951) 468-5674</a></p>
			<a href="/" class="btn btn--primary">Back to Home</a>
		</div>
	</section>
</Base>
